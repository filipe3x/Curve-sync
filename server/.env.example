PORT=3001
MONGODB_URI=mongodb://localhost:27017/embers_db_dev
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# AES-256-GCM key for encrypting imap_password and oauth_token_cache at
# rest. 64 hex chars (32 bytes). Generate with:
#   node -e "import('./src/services/crypto.js').then(m => console.log(m.generateKey()))"
IMAP_ENCRYPTION_KEY=

# --- OAuth V2 (direct XOAUTH2, no proxy — see docs/EMAIL_AUTH.md) -----
#
# Azure AD App Registration for the Microsoft/Outlook OAuth flow.
# Required once any CurveConfig has oauth_provider='microsoft'; the
# server fails fast at boot otherwise.
#
# Setup checklist (portal.azure.com → App registrations → New registration):
#   - Supported account types: "Accounts in any organizational directory
#     and personal Microsoft accounts" (tenant=common)
#   - Platform: "Mobile and desktop applications"
#   - Redirect URI: http://localhost
#   - Authentication → Advanced settings → Allow public client flows: ON
#   - API permissions (delegated):
#       * https://outlook.office.com/IMAP.AccessAsUser.All
#       * offline_access  (required — without it, no refresh token)
#
# CLIENT_SECRET is intentionally NOT required: public client + DAG/PKCE
# flows do not use one.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=common
